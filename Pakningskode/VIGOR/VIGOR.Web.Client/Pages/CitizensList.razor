@page "/citizens/{DepartmentId:int}"
@using VIGOR.Shared.Models
@inject VIGOR.Shared.Interfaces.Services.ICitizenService CitizenService

<PageTitle>Borgere</PageTitle>

<h1>Borgere</h1>

@if (_loading)
{
    <p>Indlæser borgere…</p>
}
else if (_error)
{
    <div class="alert alert-danger">Der opstod en fejl ved indlæsning af borgere.</div>
}
else if (!_citizens.Any())
{
    <p>Ingen borgere fundet på denne afdeling.</p>
}
else
{
    <ul class="list-group">
        @foreach (var c in _citizens)
        {
            <li class="list-group-item">@c.Name</li>
        }
    </ul>
}

@code {
    [Parameter]
    public int DepartmentId { get; set; }

    private bool _loading = true;
    private bool _error = false;
    private IEnumerable<Citizen> _citizens = Enumerable.Empty<Citizen>();

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = false;

        try
        {
            // Use the injected ICitizenService which for the client is backed by HTTP.
            _citizens = await CitizenService.GetCitizensByDepartmentAsync(DepartmentId);
        }
        catch
        {
            _error = true;
            _citizens = Enumerable.Empty<Citizen>();
        }
        finally
        {
            _loading = false;
        }
    }
}
