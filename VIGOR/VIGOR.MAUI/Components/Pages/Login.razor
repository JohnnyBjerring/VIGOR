@page "/"
@page "/login"
@using Microsoft.AspNetCore.Components.Authorization
@using VIGOR.Shared.Enums
@using VIGOR.Shared.Interfaces.Services
@inject IAuthService AuthService
@inject NavigationManager NavManager
@inject IAuthStateService AuthState
@inject AuthenticationStateProvider AuthStateProvider
@inject IStartPageResolver StartPageResolver
@inject IActiveShiftContextState ActiveShiftContextState

<PageTitle>Log ind – VIGOR</PageTitle>

<div class="login-page">
    <div class="login-background" aria-hidden="true"></div>

    <main class="login-shell" aria-label="Login til VIGOR">
        <section class="login-card">
            <div class="login-brand" aria-label="VIGOR">
                <img class="login-logo" src="branding/VigorLogo.svg" alt="VIGOR logo" />
                <h1>VIGOR</h1>
                <p>Visual Integrated Governance &amp; Overlap Registry</p>
            </div>

            <h2>Log ind</h2>

            <EditForm Model="@_loginModel" OnValidSubmit="OnLoginClicked" FormName="loginForm" class="login-form">
                <div class="login-field">
                    <label for="email">Email</label>
                    <InputText id="email" @bind-Value="_loginModel.Email" placeholder="din@email.dk" autocomplete="username" />
                </div>

                <div class="login-field">
                    <label for="password">Adgangskode</label>
                    <InputText id="password" type="password" @bind-Value="_loginModel.Password" placeholder="" autocomplete="current-password" />
                </div>

                <button type="submit" class="login-button" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    }
                    Log ind
                </button>
            </EditForm>

            <div class="public-link-wrap">
                <a href="public-overview">Åbn anonym oversigtsskærm</a>
            </div>

            <div class="login-message" aria-live="polite">
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <span class="login-error">@_errorMessage</span>
                }
                else if (_showSuccess)
                {
                    <span class="login-success">Login lykkedes! Omdirigerer...</span>
                }
                else
                {
                    <span>&nbsp;</span>
                }
            </div>
        </section>
    </main>

    <div class="login-micro-mark" aria-hidden="true">VIGOR</div>
</div>

@code {
    private LoginModel _loginModel = new();
    private string? _errorMessage;
    private bool _showSuccess;
    private bool _isLoading;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Hvis allerede logget ind → log ud (at besøge /login = log ud)
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true)
            {
                await ActiveShiftContextState.ClearAsync();
                await AuthState.MarkUserAsLoggedOut();
            }
        }
    }

    private async Task OnLoginClicked()
    {
        _errorMessage = null;
        _showSuccess = false;
        _isLoading = true;

        var result = await AuthService.SignInAsync(_loginModel.Email, _loginModel.Password);

        _isLoading = false;

        switch (result.Status)
        {
            case AuthStatus.Success:
                if (result.Role != null)
                {
                    await ActiveShiftContextState.ClearAsync();
                    await AuthState.MarkUserAsAuthenticated(_loginModel.Email, result.Role);

                    var startRoute = StartPageResolver.ResolveStartRoute(result.Role);
                    _showSuccess = true;
                    NavManager.NavigateTo(startRoute);
                }
                else
                {
                    _errorMessage = "Du har ikke adgang. Kontakt administrator (mangler rolle).";
                    await ActiveShiftContextState.ClearAsync();
                    await AuthState.MarkUserAsLoggedOut();
                }
                break;
            case AuthStatus.Rejected:
            case AuthStatus.Denied:
                _errorMessage = result.Message;
                break;
        }
    }

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
