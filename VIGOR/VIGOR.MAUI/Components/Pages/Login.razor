@page "/"
@page "/login"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using VIGOR.Shared.Enums
@using VIGOR.Shared.Interfaces.Services
@inject IAuthService AuthService
@inject NavigationManager NavManager
@inject IAuthStateService AuthState
@inject AuthenticationStateProvider AuthStateProvider
@inject IStartPageResolver StartPageResolver

<PageTitle>Log ind – VIGOR</PageTitle>

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <h1>VIGOR</h1>
            <p class="login-subtitle">Visual Integrated Governance &amp;<br />Overlap Registry</p>
        </div>

        <h2>Login</h2>

        <EditForm Model="@_loginModel" OnValidSubmit="OnLoginClicked" FormName="loginForm">
            <div class="login-field">
                <label for="email">Email</label>
                <InputText id="email" @bind-Value="_loginModel.Email" placeholder="din@email.dk" />
            </div>
            <div class="login-field">
                <label for="password">Adgangskode</label>
                <InputText id="password" type="password" @bind-Value="_loginModel.Password" placeholder="" />
            </div>
            <button type="submit" class="login-button" disabled="@_isLoading">
                @if (_isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                }
                Log ind
            </button>
        </EditForm>

        <div class="login-message">
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <span class="login-error">@_errorMessage</span>
            }
            else if (_showSuccess)
            {
                <span class="login-success">Login lykkedes! Omdirigerer...</span>
            }
            else
            {
                <span>&nbsp;</span>
            }
        </div>
    </div>
</div>

@code {
    private LoginModel _loginModel = new();
    private string? _errorMessage;
    private bool _showSuccess;
    private bool _isLoading;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Hvis allerede logget ind → log ud (at besøge /login = log ud)
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true)
            {
                await AuthState.MarkUserAsLoggedOut();
            }
        }
    }

    private async Task OnLoginClicked()
    {
        _errorMessage = null;
        _showSuccess = false;
        _isLoading = true;

        var result = await AuthService.SignInAsync(_loginModel.Email, _loginModel.Password);

        _isLoading = false;

        switch (result.Status)
        {
            case AuthStatus.Success:
                if (result.Role != null)
                {
                    await AuthState.MarkUserAsAuthenticated(_loginModel.Email, result.Role);
                    
                    // Brug rollen direkte fra resultatet i stedet for at læse claims igen
                    var startRoute = StartPageResolver.ResolveStartRoute(result.Role);
                    _showSuccess = true;
                    NavManager.NavigateTo(startRoute);
                }
                else
                {
                    _errorMessage = "Du har ikke adgang. Kontakt administrator (mangler rolle).";
                    await AuthState.MarkUserAsLoggedOut();
                }
                break;
            case AuthStatus.Rejected:
            case AuthStatus.Denied:
                _errorMessage = result.Message;
                break;
        }
    }

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
