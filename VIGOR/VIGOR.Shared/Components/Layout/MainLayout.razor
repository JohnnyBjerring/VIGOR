@inherits LayoutComponentBase
@implements IDisposable
@inject VIGOR.Shared.Interfaces.Services.IAuthStateService AuthStateService
@inject VIGOR.Shared.Interfaces.Services.IStartPageResolver StartPageResolver
@inject VIGOR.Shared.Interfaces.Services.IActiveShiftContextState ActiveShiftContextState
@inject NavigationManager NavigationManager

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="vigor-shell">
            <aside class="vigor-sidebar" aria-label="Hovedmenu">
                <div class="vigor-sidebar-brand">
                    <img src="branding/VigorLogo.svg" alt="VIGOR logo" />
                    <div>
                        <strong>VIGOR</strong>
                        <span>Visual Integrated Governance<br />&amp; Overlap Registry</span>
                    </div>
                </div>

                <div class="vigor-sidebar-divider"></div>
                <div class="vigor-menu-label">Menu</div>

                <nav class="vigor-nav">
                    <NavLink class="vigor-nav-link" href="@GetHomeLink(authContext.User)" Match="NavLinkMatch.All">
                        <span>⌂</span><strong>Hjem</strong>
                    </NavLink>

                    @if (HasOperationalAccess(authContext.User))
                    {
                        <NavLink class="vigor-nav-link" href="shift/select">
                            <span>◷</span><strong>Vælg vagt</strong>
                            @if (ActiveShiftContextState.Current == null)
                            {
                                <em class="nav-alert-dot">!</em>
                            }
                        </NavLink>
                        <NavLink class="vigor-nav-link" href="citizens">
                            <span>●</span><strong>Borgere</strong>
                        </NavLink>
                        <NavLink class="vigor-nav-link" href="overlap">
                            <span>⇄</span><strong>Overlap</strong>
                        </NavLink>
                    }

                    @if (CanAccessWorkPhones(authContext.User))
                    {
                        <NavLink class="vigor-nav-link" href="work-phones">
                            <span>☎</span><strong>Arbejdstelefoner</strong>
                        </NavLink>
                    }

                    @if (CanAccessStatistics(authContext.User))
                    {
                        <NavLink class="vigor-nav-link" href="statistics">
                            <span>▣</span><strong>Statistik</strong>
                        </NavLink>
                    }

                    @if (CanAccessAdministration(authContext.User))
                    {
                        <NavLink class="vigor-nav-link" href="admin/users">
                            <span>⚙</span><strong>Brugere</strong>
                        </NavLink>
                    }
                </nav>

                <div class="vigor-sidebar-spacer"></div>

                <div class="vigor-sidebar-user">
                    <strong>@GetDisplayName(authContext.User)</strong>
                    <span>Rolle: @GetPrimaryDisplayRole(authContext.User)</span>
                    <span>Aktiv vagt: @(ActiveShiftContextState.Current?.DisplayName ?? "Ingen valgt")</span>
                </div>

                <button class="vigor-logout" @onclick="Logout">Log ud</button>
                <div class="vigor-version">Version 0.2.1.19 alpha</div>
            </aside>

            <main class="vigor-content">
                @Body
            </main>
        </div>
    </Authorized>
    <NotAuthorized>
        <main class="vigor-auth-content">
            @Body
        </main>
    </NotAuthorized>
</AuthorizeView>

@code {
    protected override void OnInitialized()
    {
        ActiveShiftContextState.OnChange += HandleActiveShiftContextChanged;
    }

    private void HandleActiveShiftContextChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ActiveShiftContextState.OnChange -= HandleActiveShiftContextChanged;
    }

    private static bool HasOperationalAccess(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.IsInRole("Leder")
               || user.IsInRole("Vagtansvarlig")
               || user.IsInRole("Personale");
    }

    private static bool CanAccessAdministration(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.IsInRole("Leder") || user.IsInRole("Superbruger");
    }

    private static bool CanAccessWorkPhones(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.IsInRole("Leder")
               || user.IsInRole("Vagtansvarlig")
               || user.IsInRole("Superbruger");
    }

    private static bool CanAccessStatistics(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.IsInRole("Leder")
               || user.IsInRole("Superbruger");
    }

    private string GetHomeLink(System.Security.Claims.ClaimsPrincipal user)
    {
        var roleName = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                       ?? user.FindFirst("role")?.Value
                       ?? "Personale";

        var role = new VIGOR.Shared.Models.Role { Name = roleName };
        return StartPageResolver.ResolveStartRoute(role);
    }

    private static string GetDisplayName(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.Identity?.Name ?? "VIGOR bruger";
    }

    private static string GetPrimaryDisplayRole(System.Security.Claims.ClaimsPrincipal user)
    {
        if (user.IsInRole("Leder")) return "Leder";
        if (user.IsInRole("Vagtansvarlig")) return "Vagtansvarlig";
        if (user.IsInRole("Personale")) return "Personale";
        if (user.IsInRole("Superbruger")) return "Superbruger";
        return "Bruger";
    }

    private async Task Logout()
    {
        await ActiveShiftContextState.ClearAsync();
        await AuthStateService.MarkUserAsLoggedOut();
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }
}
