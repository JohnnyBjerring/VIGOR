@inherits LayoutComponentBase
@implements IDisposable
@inject VIGOR.Shared.Interfaces.Services.IAuthStateService AuthStateService
@inject VIGOR.Shared.Interfaces.Services.IStartPageResolver StartPageResolver
@inject VIGOR.Shared.Interfaces.Services.IActiveShiftContextState ActiveShiftContextState
@inject NavigationManager NavigationManager

<div class="d-flex w-100" style="min-height: 100vh;">
    <!-- Left Sidebar -->
    <AuthorizeView Context="authContext">
        <Authorized>
            <nav class="bg-white border-end d-flex flex-column" style="width: 250px;">
                <div class="p-4">
                    <h4 class="m-0 fw-bold">Menu</h4>
                </div>
                
                <div class="flex-grow-1 p-3">
                    <div class="mb-3">
                        <NavLink class="btn btn-outline-dark w-100 text-start" href="@GetHomeLink(authContext.User)" Match="NavLinkMatch.All">Hjem</NavLink>
                    </div>
                    <div class="mb-3">
                        <NavLink class="btn btn-outline-dark w-100 text-start" href="shift/select">Vælg vagt</NavLink>
                    </div>
                    <div class="mb-3">
                        <NavLink class="btn btn-outline-dark w-100 text-start" href="citizens">Borgere</NavLink>
                    </div>

                    @if (ActiveShiftContextState.Current != null)
                    {
                        <div class="border rounded p-2 mb-3 small bg-light">
                            <div class="text-muted">Aktiv vagt</div>
                            <div class="fw-bold">@ActiveShiftContextState.Current.DisplayName</div>
                        </div>
                    }

                    <div class="mt-4 ms-2 text-muted small">
                        Version 0.2.1.19 alpha
                    </div>
                </div>

                <div class="p-3 mt-auto">
                    <button class="btn btn-outline-dark w-100" @onclick="Logout">Log ud</button>
                </div>
            </nav>
        </Authorized>
    </AuthorizeView>

    <!-- Main Content -->
    <div class="flex-grow-1 d-flex flex-column" style="overflow-y: auto;">
        <!-- Top Header -->
        <AuthorizeView>
            <Authorized>
                <header class="p-3 border-bottom bg-white d-flex align-items-center justify-content-center" style="height: 60px;">
                    <h3 class="m-0 fw-bold">VIGOR</h3>
                </header>
            </Authorized>
        </AuthorizeView>

        <!-- Content Area -->
        <AuthorizeView>
            <Authorized>
                <main class="flex-grow-1 p-4 bg-white">
                    @Body
                </main>
            </Authorized>
            <NotAuthorized>
                <main class="flex-grow-1 p-0 m-0 w-100 h-100">
                    @Body
                </main>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        ActiveShiftContextState.OnChange += HandleActiveShiftContextChanged;
    }

    private void HandleActiveShiftContextChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ActiveShiftContextState.OnChange -= HandleActiveShiftContextChanged;
    }

    private string GetHomeLink(System.Security.Claims.ClaimsPrincipal user)
    {
        var roleName = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value 
                        ?? user.FindFirst("role")?.Value 
                        ?? "Personale";

        var role = new VIGOR.Shared.Models.Role { Name = roleName };
        return StartPageResolver.ResolveStartRoute(role);
    }

    private async Task Logout()
    {
        await ActiveShiftContextState.ClearAsync();
        await AuthStateService.MarkUserAsLoggedOut();
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }
}
