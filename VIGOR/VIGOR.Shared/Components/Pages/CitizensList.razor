@page "/citizens"
@page "/citizens/{DepartmentId:int}"
@using VIGOR.Shared.Models
@inject VIGOR.Shared.Interfaces.Services.ICitizenService CitizenService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider

<PageTitle>Borgeroversigt</PageTitle>

<div class="row align-items-center mb-4">
    <div class="col-md-6">
        <h2 class="mb-0">Borgeroversigt</h2>
    </div>
    <div class="col-md-6 text-end small">
        <span class="me-4 pr-3">Bruger: <strong>@_userName</strong></span>
        <span>Afdeling: <strong>@_departmentName</strong></span>
    </div>
</div>

@if (_selectedCitizen == null)
{
    <div class="row mb-4">
        <div class="col-md-6">
            <label for="search" class="form-label mb-1 fw-bold">Sřg borger</label>
            <div class="d-flex gap-2" style="max-width: 400px;">
                <input type="text" id="search" class="form-control border-dark" @bind="_searchTerm" @bind:event="oninput" />
            </div>
        </div>
    </div>
}

<div class="border border-dark rounded p-0" style="min-height: 400px; background-color: #fff;">
@if (_loading)
{
    <div class="p-4"><p>Indlćser borgere...</p></div>
}
else if (_error && !_citizens.Any())
{
    <div class="p-4 text-center mt-5 text-danger">Der opstod en fejl ved indlćsning: @_errorMessage</div>
}
else if (!_filteredCitizens.Any())
{
    <div class="p-4 text-center mt-5 pt-5 pb-5">
        <p>Hvis der ikke findes borgere pĺ afdelingen, vises beskeden her.</p>
    </div>
}
else
{
    @if (_selectedCitizen != null)
    {
        <div class="p-4" style="background-color: #f8f9fa;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="m-0">Borgervisning for @_selectedCitizen.Name</h3>
                <button class="btn btn-outline-dark" @onclick="CloseCitizen">Tilbage til oversigt</button>
            </div>
            
            @if (_error)
            {
                <div class="alert alert-danger" role="alert">
                    Fejl: @_errorMessage
                </div>
            }

            <div class="row align-items-center mb-4 fs-5">
                <div class="col-md-3 fw-bold">Borger-ID:</div>
                <div class="col-md-9">@_selectedCitizen.CitizenId</div>
            </div>
            
            <div class="row align-items-center mb-5 fs-5">
                <div class="col-md-3 fw-bold">Aktuel Status:</div>
                <div class="col-md-9">
                    <span class="badge @GetStatusBadgeClass(_selectedCitizen.Status)">
                        @_selectedCitizen.Status
                    </span>
                </div>
            </div>

            <!-- Adgangsbegrćnsning: Gřr det nemt at begrćnse til specifikke roller senere -->
            <AuthorizeView Roles="Leder,Vagtansvarlig,Personale">
                <Authorized>
                    <div class="border border-dark rounded p-4 bg-white" style="max-width: 600px;">
                        <h4 class="mb-3">Opdater Status</h4>
                        <div class="d-flex gap-3">
                            @foreach (var status in Enum.GetValues<VIGOR.Shared.Enums.CitizenStatus>())
                            {
                                <button class="btn text-white fs-5 fw-bold px-4 py-2 @(status == _selectedCitizen.Status ? "btn-dark border border-3 border-primary" : GetStatusButtonBackgroundClass(status))" 
                                        @onclick="@(async () => await UpdateStatusAsync(_selectedCitizen, status.ToString()))"
                                        disabled="@(_loadingStatus == status.ToString())">
                                    @if (_loadingStatus == status.ToString())
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    }
                                    @status
                                </button>
                            }
                        </div>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="alert alert-info">Du har ikke rettigheder til at ćndre status.</div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    }
    else
    {
        @if (_error)
        {
            <div class="alert alert-danger m-3" role="alert">
                Fejl: @_errorMessage
            </div>
        }
        <table class="table table-borderless m-0">
            <thead class="border-bottom border-dark">
                <tr>
                    <th class="p-3 border-end border-dark">Navn</th>
                    <th class="p-3 border-end border-dark" style="width: 15rem;">Borger-ID</th>
                    <th class="p-3 border-end border-dark" style="width: 15rem;">Status</th>
                    <th class="p-3" style="width: 15rem;">Handling</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in _filteredCitizens)
                {
                    <tr class="border-bottom">
                        <td class="p-3">@c.Name</td>
                        <td class="p-3">@c.CitizenId</td>
                        <td class="p-3 align-middle">
                            <span class="badge @GetStatusBadgeClass(c.Status)">
                                @c.Status
                            </span>
                        </td>
                        <td class="p-3 align-middle">
                            <button class="btn btn-outline-dark btn-sm px-4" @onclick="() => OpenCitizen(c)">Ĺbn</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    }
</div>

@code {
    [Parameter]
    public int? DepartmentId { get; set; }

    private bool _loading = true;
    private bool _error = false;
    private string _errorMessage = "";
    private IEnumerable<Citizen> _citizens = Enumerable.Empty<Citizen>();
    private string _searchTerm = "";

    private string _userName = "";
    private string _departmentName = "";

    private Citizen? _selectedCitizen = null;
    private string? _loadingStatus = null;

    private IEnumerable<Citizen> _filteredCitizens => 
        string.IsNullOrWhiteSpace(_searchTerm) 
            ? _citizens 
            : _citizens.Where(c => c.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userName = authState.User.Identity?.Name ?? "Ukendt bruger";
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = false;

        try
        {
            var currentDept = DepartmentId ?? 1;
            
            // Hardcode department name for now to fit wireframe format
            _departmentName = currentDept == 1 ? "Afdeling A" : (currentDept == 2 ? "Afdeling B" : "Syd");

            _citizens = await CitizenService.GetCitizensByDepartmentAsync(currentDept);
        }
        catch (Exception ex)
        {
            _error = true;
            _errorMessage = ex.Message;
            _citizens = Enumerable.Empty<Citizen>();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task UpdateStatusAsync(Citizen citizen, string? newValue)
    {
        if (string.IsNullOrEmpty(newValue) || !Enum.TryParse<VIGOR.Shared.Enums.CitizenStatus>(newValue, out var newStatus) || citizen.Status == newStatus)
        {
            return;
        }

        try
        {
            _loadingStatus = newValue;
            var currentDept = DepartmentId ?? 1;
            // Optimistic update
            var oldStatus = citizen.Status;
            citizen.Status = newStatus;

            var result = await CitizenService.UpdateCitizenStatusAsync(citizen.CitizenId, currentDept, newStatus);
            if (result == null)
            {
                // Revert on failure
                citizen.Status = oldStatus;
                _error = true;
                _errorMessage = $"Kunne ikke opdatere status for {citizen.Name}.";
            }
            else
            {
                // Clear error if success
                _error = false;
                _errorMessage = string.Empty;
                citizen.Status = result.Status;
            }
        }
        catch (Exception ex)
        {
            _error = true;
            _errorMessage = $"Fejl under opdatering af status for {citizen.Name}: {ex.Message}";
            await LoadData(); // reload on exception to reflect true state
        }
        finally
        {
            _loadingStatus = null;
        }
        StateHasChanged();
    }

    private void OpenCitizen(Citizen citizen)
    {
        _selectedCitizen = citizen;
        _error = false;
        _errorMessage = string.Empty;
    }

    private void CloseCitizen()
    {
        _selectedCitizen = null;
        _error = false;
        _errorMessage = string.Empty;
    }

    private string GetStatusBadgeClass(VIGOR.Shared.Enums.CitizenStatus status) => status switch
    {
        VIGOR.Shared.Enums.CitizenStatus.Red => "bg-danger text-white px-3 py-2 fs-6",
        VIGOR.Shared.Enums.CitizenStatus.Yellow => "bg-warning text-dark px-3 py-2 fs-6",
        VIGOR.Shared.Enums.CitizenStatus.Green => "bg-success text-white px-3 py-2 fs-6",
        _ => "bg-secondary text-white px-3 py-2 fs-6"
    };

    private string GetStatusButtonBackgroundClass(VIGOR.Shared.Enums.CitizenStatus status) => status switch
    {
        VIGOR.Shared.Enums.CitizenStatus.Red => "btn-danger",
        VIGOR.Shared.Enums.CitizenStatus.Yellow => "btn-warning text-dark",
        VIGOR.Shared.Enums.CitizenStatus.Green => "btn-success",
        _ => "btn-secondary"
    };
}

