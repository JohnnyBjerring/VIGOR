    private static string FormatGivenDateTime(DateTime? value)
    {
        if (!value.HasValue)
        {
            return "-";
        }

        return value.Value.ToLocalTime().ToString("dd-MM HH:mm", CultureInfo.InvariantCulture);
    }

    private static bool IsGivenToday(FixedMedicationDto medication)
    {
        return medication.IsGiven
            && medication.GivenAt.HasValue
            && medication.GivenAt.Value.ToLocalTime().Date == DateTime.Now.Date;
    }

    private static bool IsWithinPlannedWindow(FixedMedicationDto medication)
    {
        var now = DateTime.Now.TimeOfDay;
        var planned = medication.PlannedAt.TimeOfDay;
        var delta = Math.Abs((now - planned).TotalMinutes);

        // Simpel UC04-visning: bruges kun som vejledning, ikke som hård blokering.
        return delta <= 120 || delta >= (24 * 60) - 120;
    }

