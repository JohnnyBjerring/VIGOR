@page "/citizens"
@page "/citizens/{DepartmentId:int}"
@using System.Globalization
@using VIGOR.Shared.Models
@using VIGOR.Shared.DTOs
@inject VIGOR.Shared.Interfaces.Services.ICitizenService CitizenService
@inject VIGOR.Shared.Interfaces.Services.IFixedMedicationApi FixedMedicationApi
@inject VIGOR.Shared.Interfaces.Services.IPnMedicationApi PnMedicationApi
@inject VIGOR.Shared.Interfaces.Services.INoteApi NoteApi
@inject VIGOR.Shared.Interfaces.Services.ICitizenTaskApi CitizenTaskApi
@inject VIGOR.Shared.Interfaces.Services.IStaffAssignmentApi StaffAssignmentApi
@inject VIGOR.Shared.Interfaces.Services.IAuditEventsApi AuditEventsApi
@inject VIGOR.Shared.Interfaces.Services.IActiveShiftContextState ActiveShiftContextState
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Borgeroversigt – VIGOR</PageTitle>

<section class="vigor-page citizens-page">
    <header class="vigor-page-hero compact">
        <div>
            <div class="vigor-eyebrow">Borgeroverblik</div>
            <h1>Borgeroversigt</h1>
            <p>Overblik i kortform. Klik på en borger for medicin, noter, historik og alle detaljer.</p>
        </div>
        <div class="vigor-context-pills">
            <span class="vigor-pill">Bruger: <strong>@_userName</strong></span>
            <span class="vigor-pill">Afdeling: <strong>@_departmentName</strong></span>
            <span class="vigor-pill">Aktiv vagt: <strong>@(_activeShiftContext?.DisplayName ?? "Ingen valgt")</strong></span>
        </div>
    </header>

    @if (_selectedCitizen == null)
    {
        <section class="vigor-toolbar">
            <div class="vigor-search-box">
                <span>⌕</span>
                <div>
                    <label for="search">Søg borger</label>
                    <input type="text" id="search" class="form-control" placeholder="Søg efter navn..." @bind="_searchTerm" @bind:event="oninput" />
                </div>
            </div>
        </section>
    }

<div class="vigor-panel citizens-container">
    @if (_loading)
    {
        <div class="p-4"><p>Indlæser borgere...</p></div>
    }
    else if (_error && !_citizens.Any())
    {
        <div class="p-4 text-center mt-5 text-danger">Der opstod en fejl ved indlæsning: @_errorMessage</div>
    }
    else if (!_filteredCitizens.Any())
    {
        <div class="p-4 text-center mt-5 pt-5 pb-5">
            <p>Hvis der ikke findes borgere på afdelingen, vises beskeden her.</p>
        </div>
    }
    else
    {
        @if (_selectedCitizen != null)
        {
            <div class="p-4" style="background-color: #f8f9fa;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="m-0">Borgervisning for @_selectedCitizen.Name</h3>
                    <button class="btn btn-outline-dark" @onclick="CloseCitizen">Tilbage til oversigt</button>
                </div>

                @if (_error)
                {
                    <div class="alert alert-danger" role="alert">
                        Fejl: @_errorMessage
                    </div>
                }

                <div class="row align-items-center mb-4 fs-5">
                    <div class="col-md-3 fw-bold">Borger-ID:</div>
                    <div class="col-md-9">@_selectedCitizen.CitizenId</div>
                </div>

                <div class="row align-items-center mb-5 fs-5">
                    <div class="col-md-3 fw-bold">Aktuel Status:</div>
                    <div class="col-md-9">
                        <span class="badge @GetStatusBadgeClass(_selectedCitizen.Status)">
                            @_selectedCitizen.Status
                        </span>
                    </div>
                </div>

                <!-- Adgangsbegrænsning: Gør det nemt at begrænse til specifikke roller senere -->
                <AuthorizeView Roles="Leder,Vagtansvarlig,Personale">
                    <Authorized>
                        <div class="border border-dark rounded p-4 bg-white" style="max-width: 600px;">
                            <h4 class="mb-3">Opdater Status</h4>
                            <div class="d-flex gap-3">
                                @foreach (var status in Enum.GetValues<VIGOR.Shared.Enums.CitizenStatus>())
                                {
                                    <button class="btn text-white fs-5 fw-bold px-4 py-2 @(status == _selectedCitizen.Status ? "btn-dark border border-3 border-primary" : GetStatusButtonBackgroundClass(status))"
                                            @onclick="@(async () => await UpdateStatusAsync(_selectedCitizen, status.ToString()))"
                                            disabled="@(_loadingStatus == status.ToString())">
                                        @if (_loadingStatus == status.ToString())
                                        {
                                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                        }
                                        @status
                                    </button>
                                }
                            </div>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <div class="alert alert-info">Du har ikke rettigheder til at ændre status.</div>
                    </NotAuthorized>
                </AuthorizeView>

                <div class="border border-dark rounded p-4 bg-white mt-4" style="max-width: 1100px;">
                    <div class="d-flex justify-content-between align-items-start mb-3 gap-3 flex-wrap">
                        <div>
                            <h4 class="mb-1">Fast medicin</h4>
                            <div class="text-muted small">
                                Oversigten viser én række pr. fast medicintidspunkt og den aktuelle registrering. PN-medicin registreres i afsnittet nedenfor; fuld historik/audit håndteres i UC06.
                            </div>
                        </div>
                    </div>

                    @if (_loadingFixedMedication)
                    {
                        <div>Indlæser fast medicin...</div>
                    }
                    else if (_fixedMedications == null)
                    {
                        <div class="text-danger">Kunne ikke hente fast medicin.</div>
                    }
                    else if (!_fixedMedications.Any())
                    {
                        <div>Ingen planlagt fast medicin.</div>
                    }
                    else
                    {
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Medicin</th>
                                    <th style="width: 16rem;">Plan</th>
                                    <th style="width: 18rem;">Status</th>
                                    <th style="width: 22rem;">Handling</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var med in _fixedMedications)
                                {
                                    var isExpanded = _expandedFixedMedicationId == med.FixedMedicationId;
                                    var isWorking = _workingFixedMedicationId == med.FixedMedicationId;
                                    var hasGivenAtError = _givenAtInputErrors.TryGetValue(med.FixedMedicationId, out var givenAtInputError);
                                    var hasPlanError = _medicationPlanErrors.TryGetValue(med.FixedMedicationId, out var planError);
                                    var editState = GetMedicationEditState(med);

                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@med.Name</div>
                                            @if (!med.IsActive)
                                            {
                                                <span class="badge bg-light text-dark border">Inaktiv</span>
                                            }
                                        </td>
                                        <td>
                                            <div>@GetMedicationPlanLabel(med)</div>
                                            @if (med.IsActive && !IsWithinPlannedWindow(med))
                                            {
                                                <div class="text-muted small">Udenfor planlagt tidsvindue</div>
                                            }
                                        </td>
                                        <td>
                                            @if (!med.IsActive)
                                            {
                                                <span class="badge bg-light text-dark border">Inaktiv</span>
                                            }
                                            else if (IsGivenToday(med))
                                            {
                                                <span class="badge bg-success text-white">Givet i dag @med.GivenAt.Value.ToLocalTime().ToString("HH:mm", CultureInfo.InvariantCulture)</span>
                                            }
                                            else if (med.IsGiven && med.GivenAt.HasValue)
                                            {
                                                <span class="badge bg-warning text-dark">Sidst givet @FormatGivenDateTime(med.GivenAt)</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary text-white">Ikke givet i dag</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex gap-2 flex-wrap">
                                                <button class="btn btn-outline-dark btn-sm"
                                                        @onclick="@(async () => await RegisterFixedMedicationNowAsync(med))"
                                                        disabled="@(isWorking || !med.IsActive)">
                                                    @if (isWorking)
                                                    {
                                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                                    }
                                                    Registrer givet
                                                </button>

                                                <button class="btn btn-outline-secondary btn-sm"
                                                        @onclick="@(async () => await ToggleMedicationDetailsAsync(med))"
                                                        disabled="@isWorking">
                                                    @if (isExpanded)
                                                    {
                                                        <span>Skjul</span>
                                                    }
                                                    else
                                                    {
                                                        <AuthorizeView Roles="Leder,Vagtansvarlig">
                                                            <Authorized>Ret registrering / medicinplan</Authorized>
                                                            <NotAuthorized>Ret registrering</NotAuthorized>
                                                        </AuthorizeView>
                                                    }
                                                </button>
                                            </div>
                                            @if (!med.IsActive)
                                            {
                                                <div class="text-muted small mt-1">Inaktiv medicinplan kan ikke registreres som givet.</div>
                                            }
                                        </td>
                                    </tr>

                                    @if (isExpanded)
                                    {
                                        <tr class="bg-light">
                                            <td colspan="4" class="p-3 border-bottom">
                                                <div class="row g-4">
                                                    <div class="col-lg-6">
                                                        <div class="border rounded p-3 bg-white h-100">
                                                            <h5 class="mb-3">Registrering</h5>
                                                            <label class="form-label fw-bold" for="given-at-@med.FixedMedicationId">Givet tidspunkt</label>
                                                            <input id="given-at-@med.FixedMedicationId"
                                                                   type="datetime-local"
                                                                   class="form-control form-control-sm @(hasGivenAtError ? "is-invalid" : string.Empty)"
                                                                   value="@GetGivenAtInputValue(med)"
                                                                   min="@MinimumGivenAtInputValue"
                                                                   step="60"
                                                                   aria-invalid="@(hasGivenAtError ? "true" : "false")"
                                                                   @oninput="@(e => SetGivenAtInputValue(med.FixedMedicationId, e.Value))"
                                                                   @onchange="@(e => SetGivenAtInputValue(med.FixedMedicationId, e.Value))" />
                                                            @if (hasGivenAtError)
                                                            {
                                                                <div class="invalid-feedback d-block">@givenAtInputError</div>
                                                            }
                                                            else
                                                            {
                                                                <div class="form-text">Tomt felt registrerer med serverens nuværende tidspunkt.</div>
                                                            }

                                                            <div class="d-flex gap-2 flex-wrap mt-3">
                                                                <button class="btn btn-outline-dark btn-sm"
                                                                        @onclick="@(async () => await SaveFixedMedicationRegistrationAsync(med))"
                                                                        disabled="@(isWorking || !med.IsActive)">
                                                                    Gem aktuel registrering
                                                                </button>

                                                                @if (med.IsGiven)
                                                                {
                                                                    <button class="btn btn-outline-danger btn-sm"
                                                                            @onclick="@(async () => await CancelFixedMedicationAsync(med))"
                                                                            disabled="@isWorking">
                                                                        Annuller aktuel registrering
                                                                    </button>
                                                                }
                                                            </div>
                                                            <div class="form-text mt-2">
                                                                UC04 viser og ændrer kun den aktuelle registrering. Historik og audit håndteres i senere use cases.
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <AuthorizeView Roles="Leder,Vagtansvarlig">
                                                        <Authorized>
                                                            <div class="col-lg-6">
                                                                <div class="border rounded p-3 bg-white h-100">
                                                                    <h5 class="mb-3">Medicinplan (fast tidspunkt)</h5>
                                                                    @if (hasPlanError)
                                                                    {
                                                                        <div class="alert alert-danger py-2" role="alert">@planError</div>
                                                                    }

                                                                    <div class="mb-2">
                                                                        <label class="form-label fw-bold" for="med-name-@med.FixedMedicationId">Navn</label>
                                                                        <input id="med-name-@med.FixedMedicationId"
                                                                               class="form-control form-control-sm"
                                                                               value="@editState.Name"
                                                                               maxlength="100"
                                                                               @oninput="@(e => SetMedicationName(med.FixedMedicationId, e.Value))"
                                                                               @onchange="@(e => SetMedicationName(med.FixedMedicationId, e.Value))" />
                                                                    </div>

                                                                    <div class="mb-2">
                                                                        <label class="form-label fw-bold" for="planned-time-@med.FixedMedicationId">Fast klokkeslæt</label>
                                                                        <input id="planned-time-@med.FixedMedicationId"
                                                                               type="time"
                                                                               class="form-control form-control-sm"
                                                                               value="@editState.PlannedTime"
                                                                               step="60"
                                                                               @oninput="@(e => SetMedicationPlannedTime(med.FixedMedicationId, e.Value))"
                                                                               @onchange="@(e => SetMedicationPlannedTime(med.FixedMedicationId, e.Value))" />
                                                                    </div>

                                                                    <div class="form-check mb-3">
                                                                        <input id="active-@med.FixedMedicationId"
                                                                               class="form-check-input"
                                                                               type="checkbox"
                                                                               @bind="editState.IsActive" />
                                                                        <label class="form-check-label" for="active-@med.FixedMedicationId">Aktiv medicinplan</label>
                                                                    </div>

                                                                    <button class="btn btn-outline-dark btn-sm"
                                                                            @onclick="@(async () => await SaveMedicationPlanAsync(med))"
                                                                            disabled="@isWorking">
                                                                        Gem medicinplan
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </Authorized>
                                                    </AuthorizeView>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="border border-dark rounded p-4 bg-white mt-4" style="max-width: 1100px;">
                    <div class="d-flex justify-content-between align-items-start mb-3 gap-3 flex-wrap">
                        <div>
                            <h4 class="mb-1">PN-medicin</h4>
                            <div class="text-muted small">
                                UC05 registrerer PN-medicin givet ved behov. Hver registrering gemmes med borger, bruger, tidspunkt og aktiv vagt.
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_pnMedicationError))
                    {
                        <div class="alert alert-danger py-2" role="alert">@_pnMedicationError</div>
                    }

                    <div class="border rounded p-3 bg-light mb-4">
                        <h5 class="mb-3">Registrer PN-medicin</h5>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold" for="pn-name">Medicin</label>
                                <input id="pn-name"
                                       class="form-control form-control-sm"
                                       maxlength="100"
                                       placeholder="Fx Panodil"
                                       @bind="_pnForm.MedicineName"
                                       @bind:event="oninput" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-bold" for="pn-dose">Dosis</label>
                                <input id="pn-dose"
                                       class="form-control form-control-sm"
                                       maxlength="60"
                                       placeholder="Fx 1 tablet"
                                       @bind="_pnForm.Dose"
                                       @bind:event="oninput" />
                            </div>
                            <div class="col-md-5">
                                <label class="form-label fw-bold" for="pn-given-at">Givet tidspunkt</label>
                                <input id="pn-given-at"
                                       type="datetime-local"
                                       class="form-control form-control-sm"
                                       min="@MinimumGivenAtInputValue"
                                       step="60"
                                       value="@_pnForm.GivenAtInput"
                                       @oninput="@(e => SetPnGivenAtInputValue(e.Value))"
                                       @onchange="@(e => SetPnGivenAtInputValue(e.Value))" />
                                <div class="form-text">Tomt felt registrerer med serverens nuværende tidspunkt.</div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold" for="pn-reason">Årsag / behov</label>
                                <textarea id="pn-reason"
                                          class="form-control form-control-sm"
                                          maxlength="250"
                                          rows="2"
                                          placeholder="Fx smerter, uro eller andet konkret behov"
                                          @bind="_pnForm.Reason"
                                          @bind:event="oninput"></textarea>
                            </div>
                            <div class="col-12 d-flex align-items-center gap-3 flex-wrap">
                                <button class="btn btn-outline-dark btn-sm"
                                        @onclick="RegisterPnMedicationAsync"
                                        disabled="@_savingPnMedication">
                                    @if (_savingPnMedication)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    }
                                    Registrer PN-medicin
                                </button>
                                <span class="text-muted small">Aktiv vagt: <strong>@(_activeShiftContext?.DisplayName ?? "Ingen valgt")</strong></span>
                            </div>
                        </div>
                    </div>

                    @if (_loadingPnMedication)
                    {
                        <div>Indlæser PN-medicin...</div>
                    }
                    else if (_pnMedications == null)
                    {
                        <div class="text-danger">Kunne ikke hente PN-medicin.</div>
                    }
                    else if (!_pnMedications.Any())
                    {
                        <div>Ingen PN-medicin registreret for borgeren endnu.</div>
                    }
                    else
                    {
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Medicin</th>
                                    <th>Dosis</th>
                                    <th>Årsag / behov</th>
                                    <th style="width: 10rem;">Vagt</th>
                                    <th style="width: 12rem;">Givet</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var med in _pnMedications)
                                {
                                    <tr>
                                        <td>@med.MedicineName</td>
                                        <td>@med.Dose</td>
                                        <td>@med.Reason</td>
                                        <td>@med.ShiftDisplayName</td>
                                        <td>@FormatGivenDateTime(med.GivenAtUtc)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="border border-dark rounded p-4 bg-white mt-4" style="max-width: 1100px;">
                    <div class="d-flex justify-content-between align-items-start mb-3 gap-3 flex-wrap">
                        <div>
                            <h4 class="mb-1">Tildelt personale</h4>
                            <div class="text-muted small">
                                UC11 tildeler personale til en borger. Tildelingen gemmes med brugerreference og tidspunkt og vises også i overlap.
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_staffAssignmentError))
                    {
                        <div class="alert alert-danger py-2" role="alert">@_staffAssignmentError</div>
                    }

                    <AuthorizeView Roles="Leder,Vagtansvarlig">
                        <Authorized>
                            <div class="border rounded p-3 bg-light mb-4">
                                <h5 class="mb-3">Tildel personale</h5>
                                <div class="row g-3 align-items-end">
                                    <div class="col-md-8">
                                        <label class="form-label fw-bold" for="staff-assignment-employee">Medarbejder</label>
                                        <select id="staff-assignment-employee"
                                                class="form-select form-select-sm"
                                                @bind="_selectedStaffEmployeeId"
                                                disabled="@(_savingStaffAssignment || _loadingStaffAssignments)">
                                            <option value="">Vælg medarbejder fra din afdeling</option>
                                            @if (_assignableStaff != null)
                                            {
                                                @foreach (var staff in _assignableStaff)
                                                {
                                                    <option value="@staff.EmployeeId">@FormatStaffWithPhone(staff)</option>
                                                }
                                            }
                                        </select>
                                        <div class="form-text">Kun personale fra den indloggede brugers afdeling kan tildeles.</div>
                                    </div>
                                    <div class="col-md-4">
                                        <button class="btn btn-outline-dark btn-sm"
                                                @onclick="AssignStaffAsync"
                                                disabled="@(_savingStaffAssignment || _loadingStaffAssignments)">
                                            @if (_savingStaffAssignment)
                                            {
                                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                            }
                                            Tildel personale
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </Authorized>
                    </AuthorizeView>

                    @if (_loadingStaffAssignments)
                    {
                        <div>Indlæser personaletildelinger...</div>
                    }
                    else if (_staffAssignments == null)
                    {
                        <div class="text-danger">Kunne ikke hente personaletildelinger.</div>
                    }
                    else if (!_staffAssignments.Any(a => a.IsActive))
                    {
                        <div>Der er endnu ikke tildelt personale til borgeren.</div>
                    }
                    else
                    {
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Medarbejder</th>
                                    <th style="width: 12rem;">Telefon</th>
                                    <th style="width: 12rem;">Tildelt</th>
                                    <th style="width: 12rem;">Tildelt af</th>
                                    <AuthorizeView Roles="Leder,Vagtansvarlig">
                                        <Authorized>
                                            <th style="width: 9rem;">Handling</th>
                                        </Authorized>
                                    </AuthorizeView>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var assignment in _staffAssignments.Where(a => a.IsActive))
                                {
                                    var isRemoving = _unassigningStaffAssignmentId == assignment.CitizenStaffAssignmentId;
                                    <tr>
                                        <td>@assignment.EmployeeNameSnapshot</td>
                                        <td>@(string.IsNullOrWhiteSpace(assignment.ActivePhoneDisplayName) ? "Ingen telefon" : assignment.ActivePhoneDisplayName)</td>
                                        <td>@FormatStaffAssignmentDateTime(assignment.AssignedAtUtc)</td>
                                        <td>@assignment.AssignedByUserId</td>
                                        <AuthorizeView Roles="Leder,Vagtansvarlig">
                                            <Authorized>
                                                <td>
                                                    <button class="btn btn-outline-danger btn-sm"
                                                            @onclick="@(async () => await UnassignStaffAsync(assignment))"
                                                            disabled="@isRemoving">
                                                        @if (isRemoving)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                                        }
                                                        Fjern
                                                    </button>
                                                </td>
                                            </Authorized>
                                        </AuthorizeView>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>


                <div class="border border-dark rounded p-4 bg-white mt-4" style="max-width: 1100px;">
                    <div class="d-flex justify-content-between align-items-start mb-3 gap-3 flex-wrap">
                        <div>
                            <h4 class="mb-1">Noter</h4>
                            <div class="text-muted small">
                                UC09 opretter faglige noter på den valgte borger. Noter gemmes med bruger, tidspunkt, afdeling og aktiv vagt.
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_noteError))
                    {
                        <div class="alert alert-danger py-2" role="alert">@_noteError</div>
                    }

                    <div class="border rounded p-3 bg-light mb-4">
                        <h5 class="mb-3">Opret note</h5>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-bold" for="note-content">Note</label>
                                <textarea id="note-content"
                                          class="form-control form-control-sm"
                                          maxlength="1000"
                                          rows="3"
                                          placeholder="Skriv en kort faglig note til overlap"
                                          @bind="_noteForm.Content"
                                          @bind:event="oninput"></textarea>
                                <div class="form-text">Maks 1000 tegn. Aktiv vagt gemmes sammen med noten.</div>
                            </div>
                            <div class="col-12 d-flex align-items-center gap-3 flex-wrap">
                                <button class="btn btn-outline-dark btn-sm"
                                        @onclick="CreateNoteAsync"
                                        disabled="@_savingNote">
                                    @if (_savingNote)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    }
                                    Gem note
                                </button>
                                <span class="text-muted small">Aktiv vagt: <strong>@(_activeShiftContext?.DisplayName ?? "Ingen valgt")</strong></span>
                            </div>
                        </div>
                    </div>

                    @if (_loadingNotes)
                    {
                        <div>Indlæser noter...</div>
                    }
                    else if (_notes == null)
                    {
                        <div class="text-danger">Kunne ikke hente noter.</div>
                    }
                    else if (!_notes.Any())
                    {
                        <div>Der er endnu ingen noter for borgeren.</div>
                    }
                    else
                    {
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 10rem;">Tidspunkt</th>
                                    <th>Note</th>
                                    <th style="width: 12rem;">Bruger</th>
                                    <th style="width: 10rem;">Vagt</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var note in _notes)
                                {
                                    <tr>
                                        <td>@FormatNoteDateTime(note.CreatedAtUtc)</td>
                                        <td>@note.Content</td>
                                        <td>@FormatNoteUser(note)</td>
                                        <td>@note.ShiftDisplayName</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>


                <div class="border border-dark rounded p-4 bg-white mt-4" style="max-width: 1100px;">
                    <div class="d-flex justify-content-between align-items-start mb-3 gap-3 flex-wrap">
                        <div>
                            <h4 class="mb-1">Opgaver</h4>
                            <div class="text-muted small">
                                UC10 opretter opgaver på den valgte borger og gør det muligt at markere dem som afsluttet.
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_taskError))
                    {
                        <div class="alert alert-danger py-2" role="alert">@_taskError</div>
                    }

                    <div class="border rounded p-3 bg-light mb-4">
                        <h5 class="mb-3">Opret opgave</h5>
                        <div class="row g-3">
                            <div class="col-md-5">
                                <label class="form-label fw-bold" for="task-title">Titel</label>
                                <input id="task-title"
                                       type="text"
                                       class="form-control form-control-sm"
                                       maxlength="120"
                                       placeholder="Fx Husk væskeskema"
                                       @bind="_taskForm.Title"
                                       @bind:event="oninput" />
                            </div>
                            <div class="col-md-7">
                                <label class="form-label fw-bold" for="task-description">Beskrivelse</label>
                                <textarea id="task-description"
                                          class="form-control form-control-sm"
                                          maxlength="1000"
                                          rows="2"
                                          placeholder="Valgfri kort beskrivelse af opgaven"
                                          @bind="_taskForm.Description"
                                          @bind:event="oninput"></textarea>
                            </div>
                            <div class="col-12 d-flex align-items-center gap-3 flex-wrap">
                                <button class="btn btn-outline-dark btn-sm"
                                        @onclick="CreateTaskAsync"
                                        disabled="@_savingTask">
                                    @if (_savingTask)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    }
                                    Gem opgave
                                </button>
                                <span class="text-muted small">Aktiv vagt: <strong>@(_activeShiftContext?.DisplayName ?? "Ingen valgt")</strong></span>
                            </div>
                        </div>
                    </div>

                    @if (_loadingTasks)
                    {
                        <div>Indlæser opgaver...</div>
                    }
                    else if (_tasks == null)
                    {
                        <div class="text-danger">Kunne ikke hente opgaver.</div>
                    }
                    else if (!_tasks.Any(t => !t.IsCompleted))
                    {
                        <div>Der er ingen aktive opgaver for borgeren.</div>
                    }
                    else
                    {
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 10rem;">Oprettet</th>
                                    <th style="width: 14rem;">Titel</th>
                                    <th>Beskrivelse</th>
                                    <th style="width: 12rem;">Bruger</th>
                                    <th style="width: 10rem;">Vagt</th>
                                    <th style="width: 9rem;">Handling</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var task in _tasks.Where(t => !t.IsCompleted))
                                {
                                    <tr>
                                        <td>@FormatTaskDateTime(task.CreatedAtUtc)</td>
                                        <td>@task.Title</td>
                                        <td>@(string.IsNullOrWhiteSpace(task.Description) ? "-" : task.Description)</td>
                                        <td>@FormatTaskCreatedByUser(task)</td>
                                        <td>@task.ShiftDisplayName</td>
                                        <td>
                                            <button class="btn btn-outline-success btn-sm"
                                                    @onclick="@(async () => await CompleteTaskAsync(task))"
                                                    disabled="@(_completingTaskId == task.CitizenTaskId)">
                                                @if (_completingTaskId == task.CitizenTaskId)
                                                {
                                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                                }
                                                Afslut
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="border border-dark rounded p-4 bg-white mt-4" style="max-width: 1100px;">
                    <div class="d-flex justify-content-between align-items-start mb-3 gap-3 flex-wrap">
                        <div>
                            <h4 class="mb-1">Historik / audit-log</h4>
                            <div class="text-muted small">
                                UC06 viser centrale hændelser for borgeren. Audit oprettes server-side og kan ikke oprettes direkte fra klienten.
                            </div>
                        </div>
                        <button class="btn btn-outline-secondary btn-sm"
                                @onclick="LoadAuditEventsAsync"
                                disabled="@_loadingAuditEvents">
                            @if (_loadingAuditEvents)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            }
                            Opdatér historik
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_auditEventsError))
                    {
                        <div class="alert alert-danger py-2" role="alert">@_auditEventsError</div>
                    }

                    @if (_loadingAuditEvents)
                    {
                        <div>Indlæser historik...</div>
                    }
                    else if (_auditEvents == null)
                    {
                        <div class="text-danger">Kunne ikke hente historik.</div>
                    }
                    else if (!_auditEvents.Any())
                    {
                        <div>Der er endnu ingen historik for borgeren.</div>
                    }
                    else
                    {
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 10rem;">Tidspunkt</th>
                                    <th style="width: 14rem;">Hændelse</th>
                                    <th>Beskrivelse</th>
                                    <th style="width: 12rem;">Bruger</th>
                                    <th style="width: 10rem;">Vagt</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var auditEvent in _auditEvents)
                                {
                                    <tr>
                                        <td>@FormatAuditDateTime(auditEvent.CreatedAtUtc)</td>
                                        <td>@GetAuditActionLabel(auditEvent.Action)</td>
                                        <td>@auditEvent.Description</td>
                                        <td>@FormatAuditUser(auditEvent)</td>
                                        <td>@(auditEvent.ShiftDisplayName ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        }
        else
        {
            @if (_error)
            {
                <div class="vigor-alert danger" role="alert">Fejl: @_errorMessage</div>
            }
            <div class="vigor-panel-head citizens-list-head">
                <div>
                    <h2>Borgere på afdelingen</h2>
                    <p>@(_searchTerm.Length == 0 ? "Viser alle borgere" : $"Søger efter: {_searchTerm}")</p>
                </div>
            </div>
            <div class="citizen-card-grid">
                @foreach (var c in _filteredCitizens)
                {
                    <article class="citizen-overview-card status-@c.Status.ToString().ToLowerInvariant()" role="button" tabindex="0" @onclick="@(async () => await OpenCitizenAsync(c))">
                        <header>
                            <div>
                                <h3>@c.Name</h3>
                                <p>Borger-ID: @c.CitizenId</p>
                            </div>
                            <span class="vigor-status-badge @GetStatusBadgeClass(c.Status)">@c.Status</span>
                        </header>
                        <div class="citizen-card-summary">
                            <span>Aktuelt fokus</span>
                            <strong>@GetCitizenOverviewFocus(c.Status)</strong>
                        </div>
                        <footer>
                            <span>Detaljer åbnes på borgerkortet</span>
                            <b>Klik for detaljer</b>
                        </footer>
                    </article>
                }
            </div>
}
    }
</div>
</section>

@code {
    [Parameter]
    public int? DepartmentId { get; set; }

    private bool _loading = true;
    private bool _error = false;
    private string _errorMessage = "";
    private IEnumerable<Citizen> _citizens = Enumerable.Empty<Citizen>();
    private string _searchTerm = "";

    private string _userName = "";
    private string _departmentName = "Min afdeling";
    private ActiveShiftContextDto? _activeShiftContext;

    private Citizen? _selectedCitizen = null;
    private string? _loadingStatus = null;

    private bool _loadingFixedMedication = false;
    private List<FixedMedicationDto>? _fixedMedications = null;
    private int? _workingFixedMedicationId = null;
    private int? _expandedFixedMedicationId = null;

    private bool _loadingPnMedication = false;
    private bool _savingPnMedication = false;
    private List<PnMedicationDto>? _pnMedications = null;
    private string _pnMedicationError = string.Empty;
    private PnMedicationFormState _pnForm = PnMedicationFormState.CreateDefault();

    private bool _loadingNotes = false;
    private bool _savingNote = false;
    private List<NoteDto>? _notes = null;
    private string _noteError = string.Empty;
    private NoteFormState _noteForm = new();

    private bool _loadingTasks = false;
    private bool _savingTask = false;
    private int? _completingTaskId = null;
    private List<CitizenTaskDto>? _tasks = null;
    private string _taskError = string.Empty;
    private TaskFormState _taskForm = new();

    private bool _loadingStaffAssignments = false;
    private bool _savingStaffAssignment = false;
    private int? _unassigningStaffAssignmentId = null;
    private List<CitizenStaffAssignmentDto>? _staffAssignments = null;
    private List<AssignableStaffDto>? _assignableStaff = null;
    private string _staffAssignmentError = string.Empty;
    private string _selectedStaffEmployeeId = string.Empty;

    private bool _loadingAuditEvents = false;
    private List<AuditEventDto>? _auditEvents = null;
    private string _auditEventsError = string.Empty;

    private const string GivenAtDisplayFormat = "yyyy-MM-ddTHH:mm";
    private const string MinimumGivenAtInputValue = "2000-01-01T00:00";
    private static readonly DateTime MinimumGivenAtLocal = new(2000, 1, 1, 0, 0, 0);
    private static readonly string[] GivenAtInputFormats =
    {
        "yyyy-MM-ddTHH:mm",
        "yyyy-MM-ddTHH:mm:ss",
        "yyyy-MM-ddTHH:mm:ss.FFF",
        "yyyy-MM-ddTHH:mm:ss.fffffff"
    };

    private readonly Dictionary<int, string> _givenAtInputs = new();
    private readonly Dictionary<int, string> _givenAtInputErrors = new();
    private readonly Dictionary<int, FixedMedicationEditState> _medicationEditStates = new();
    private readonly Dictionary<int, string> _medicationPlanErrors = new();

    private IEnumerable<Citizen> _filteredCitizens =>
        string.IsNullOrWhiteSpace(_searchTerm)
            ? _citizens
            : _citizens.Where(c => c.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userName = authState.User.Identity?.Name ?? "Ukendt bruger";
        _activeShiftContext = ActiveShiftContextState.Current;
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = false;

        try
        {
            _activeShiftContext = ActiveShiftContextState.Current;

            if (_activeShiftContext == null)
            {
                _loading = false;
                NavigationManager.NavigateTo("/shift/select");
                return;
            }

            var currentDept = DepartmentId ?? 1;

            // Afdeling vises neutralt, fordi serveren udleder den sikre afdeling fra den autentificerede bruger.
            // Route-parameteren bevares kun af hensyn til eksisterende klient/service-kontrakt.
            _departmentName = "Min afdeling";

            _citizens = await CitizenService.GetCitizensByDepartmentAsync(currentDept);
        }
        catch (Exception ex)
        {
            _error = true;
            _errorMessage = ex.Message;
            _citizens = Enumerable.Empty<Citizen>();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task UpdateStatusAsync(Citizen citizen, string? newValue)
    {
        if (string.IsNullOrEmpty(newValue) || !Enum.TryParse<VIGOR.Shared.Enums.CitizenStatus>(newValue, out var newStatus) || citizen.Status == newStatus)
        {
            return;
        }

        try
        {
            _loadingStatus = newValue;
            var currentDept = DepartmentId ?? 1;

            // Optimistic update
            var oldStatus = citizen.Status;
            citizen.Status = newStatus;

            var result = await CitizenService.UpdateCitizenStatusAsync(citizen.CitizenId, currentDept, newStatus);
            if (result == null)
            {
                // Revert on failure
                citizen.Status = oldStatus;
                _error = true;
                _errorMessage = $"Kunne ikke opdatere status for {citizen.Name}.";
            }
            else
            {
                // Clear error if success
                _error = false;
                _errorMessage = string.Empty;
                citizen.Status = result.Status;
                await LoadAuditEventsAsync();
            }
        }
        catch (Exception ex)
        {
            _error = true;
            _errorMessage = $"Fejl under opdatering af status for {citizen.Name}: {ex.Message}";
            await LoadData(); // reload on exception to reflect true state
        }
        finally
        {
            _loadingStatus = null;
        }

        StateHasChanged();
    }

    private async Task OpenCitizenAsync(Citizen citizen)
    {
        _selectedCitizen = citizen;
        _error = false;
        _errorMessage = string.Empty;
        await LoadFixedMedicationAsync();
        await LoadPnMedicationAsync();
        await LoadNotesAsync();
        await LoadTasksAsync();
        await LoadStaffAssignmentsAsync();
        await LoadAuditEventsAsync();
    }

    private void CloseCitizen()
    {
        _selectedCitizen = null;
        _error = false;
        _errorMessage = string.Empty;
        _fixedMedications = null;
        _pnMedications = null;
        _pnMedicationError = string.Empty;
        _pnForm = PnMedicationFormState.CreateDefault();
        _notes = null;
        _noteError = string.Empty;
        _noteForm = new NoteFormState();
        _tasks = null;
        _taskError = string.Empty;
        _taskForm = new TaskFormState();
        _completingTaskId = null;
        _staffAssignments = null;
        _assignableStaff = null;
        _staffAssignmentError = string.Empty;
        _selectedStaffEmployeeId = string.Empty;
        _unassigningStaffAssignmentId = null;
        _auditEvents = null;
        _auditEventsError = string.Empty;
        _givenAtInputs.Clear();
        _givenAtInputErrors.Clear();
        _medicationEditStates.Clear();
        _medicationPlanErrors.Clear();
        _expandedFixedMedicationId = null;
    }

    private async Task LoadFixedMedicationAsync()
    {
        if (_selectedCitizen == null)
        {
            return;
        }

        _loadingFixedMedication = true;

        try
        {
            var meds = await FixedMedicationApi.GetFixedMedicationsForCitizenAsync(_selectedCitizen.CitizenId);
            _fixedMedications = meds?.ToList();

            if (_fixedMedications != null)
            {
                SyncGivenAtInputs(_fixedMedications);
                SyncMedicationEditStates(_fixedMedications);
            }
        }
        catch (Exception ex)
        {
            _error = true;
            _errorMessage = $"Fejl under hentning af fast medicin: {ex.Message}";
            _fixedMedications = null;
            _givenAtInputs.Clear();
            _givenAtInputErrors.Clear();
            _medicationEditStates.Clear();
            _medicationPlanErrors.Clear();
        }
        finally
        {
            _loadingFixedMedication = false;
            StateHasChanged();
        }
    }

    private async Task LoadPnMedicationAsync()
    {
        if (_selectedCitizen == null)
        {
            return;
        }

        _loadingPnMedication = true;
        _pnMedicationError = string.Empty;

        try
