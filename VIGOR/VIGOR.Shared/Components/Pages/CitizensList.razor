    private static bool TryCreatePlanRequest(FixedMedicationEditState state, out UpdateFixedMedicationPlanRequest request, out string validationError)
    {
        request = new UpdateFixedMedicationPlanRequest();
        validationError = string.Empty;

        var name = state.Name.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            validationError = "Medicinens navn mangler. Skriv et navn, fx Panodil 1g.";
            return false;
        }

        var scheduleDescription = string.IsNullOrWhiteSpace(state.ScheduleDescription)
            ? "Fast tidspunkt"
            : state.ScheduleDescription.Trim();

        if (!TryParsePlannedTime(state.PlannedTime, out var plannedAt))
        {
            validationError = "Planlagt klokkeslæt kunne ikke læses. Vælg klokkeslæt igen, fx 08:00.";
            return false;
        }

        request = new UpdateFixedMedicationPlanRequest
        {
            Name = name,
            PlannedAt = plannedAt,
            ScheduleDescription = scheduleDescription,
            IsActive = state.IsActive
        };

        return true;
    }

    private static bool TryParsePlannedTime(string value, out DateTime plannedAt)
    {
        plannedAt = default;

        TimeSpan parsedTime;
        if (TimeSpan.TryParseExact(value, @"hh\:mm", CultureInfo.InvariantCulture, out parsedTime)
            || TimeSpan.TryParse(value, CultureInfo.CurrentCulture, out parsedTime)
            || TimeSpan.TryParse(value, CultureInfo.InvariantCulture, out parsedTime))
        {
            plannedAt = new DateTime(2000, 1, 1, parsedTime.Hours, parsedTime.Minutes, 0, DateTimeKind.Unspecified);
            return true;
        }

        return false;
    }

    private static string GetDefaultGivenAtInputValue(FixedMedicationDto medication)
    {
        if (medication.IsGiven && medication.GivenAt.HasValue)
