            return medication.GivenAt.Value.ToLocalTime().ToString(GivenAtDisplayFormat, CultureInfo.InvariantCulture);
        }

        return DateTime.Now.ToString(GivenAtDisplayFormat, CultureInfo.InvariantCulture);
