    private async Task RegisterPnMedicationAsync()
    {
        if (_selectedCitizen == null)
        {
            return;
        }

        _activeShiftContext = ActiveShiftContextState.Current;
        if (_activeShiftContext == null)
        {
            _pnMedicationError = "Der er ikke valgt aktiv vagt. Vælg dagvagt, aftenvagt eller nattevagt først.";
            NavigationManager.NavigateTo("/shift/select");
            return;
        }

        if (!TryCreatePnMedicationRequest(out var request, out var validationError))
        {
            _pnMedicationError = validationError;
            return;
        }

        try
        {
            _savingPnMedication = true;
            _pnMedicationError = string.Empty;

            var result = await PnMedicationApi.RegisterPnMedicationAsync(_selectedCitizen.CitizenId, request);
            if (result == null)
            {
                _pnMedicationError = "Kunne ikke registrere PN-medicin. Serveren returnerede ikke en registrering.";
                return;
            }

            _pnForm = PnMedicationFormState.CreateDefault();
            await LoadPnMedicationAsync();
            await LoadAuditEventsAsync();
        }
        catch (Exception ex)
        {
            _pnMedicationError = $"Fejl under registrering af PN-medicin: {ex.Message}";
        }
        finally
        {
            _savingPnMedication = false;
            StateHasChanged();
        }
    }


    private void SetPnGivenAtInputValue(object? value)
    {
        _pnForm.GivenAtInput = NormalizeGivenAtInputValue(value);
        _pnMedicationError = string.Empty;
    }

    private bool TryCreatePnMedicationRequest(out RegisterPnMedicationRequest request, out string validationError)
    {
        request = new RegisterPnMedicationRequest();
        validationError = string.Empty;

        var medicineName = _pnForm.MedicineName.Trim();
        if (string.IsNullOrWhiteSpace(medicineName))
        {
            validationError = "Medicinens navn mangler. Skriv et navn, fx Panodil.";
            return false;
        }

        var dose = _pnForm.Dose.Trim();
        if (string.IsNullOrWhiteSpace(dose))
        {
            validationError = "Dosis mangler. Skriv dosis, fx 1 tablet eller 5 mg.";
            return false;
        }

        var reason = _pnForm.Reason.Trim();
        if (string.IsNullOrWhiteSpace(reason))
        {
            validationError = "Årsag/behov mangler. Skriv kort hvorfor PN-medicinen gives.";
            return false;
        }

        if (!TryResolvePnGivenAtUtc(out var givenAtUtc, out validationError))
        {
            return false;
        }

        request = new RegisterPnMedicationRequest
        {
            MedicineName = medicineName,
            Dose = dose,
            Reason = reason,
            GivenAt = givenAtUtc,
            ShiftType = _activeShiftContext!.ShiftType
        };

        return true;
    }

    private bool TryResolvePnGivenAtUtc(out DateTime? givenAtUtc, out string validationError)
    {
        givenAtUtc = null;
        validationError = string.Empty;

        var value = _pnForm.GivenAtInput?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        if (!TryParseGivenAtInput(value, out var parsedGivenAt))
        {
            validationError = "Tidspunktet for PN-medicin kunne ikke læses. Vælg dato og klokkeslæt igen. Tomt felt er også tilladt og registrerer med serverens nuværende tidspunkt.";
            return false;
        }

        var localComparisonValue = parsedGivenAt.Kind == DateTimeKind.Utc
            ? parsedGivenAt.ToLocalTime()
            : parsedGivenAt;

        if (localComparisonValue < MinimumGivenAtLocal)
        {
            validationError = "Tidspunktet for PN-medicin er ugyldigt, fordi det ligger før 01-01-2000 kl. 00:00. Vælg et nyere tidspunkt eller ryd feltet for at bruge serverens nuværende tidspunkt.";
            return false;
        }

        givenAtUtc = ConvertParsedGivenAtToUtc(parsedGivenAt);
        return true;
    }

    private Task ToggleMedicationDetailsAsync(FixedMedicationDto med)
    {
        _expandedFixedMedicationId = _expandedFixedMedicationId == med.FixedMedicationId
            ? null
            : med.FixedMedicationId;

        _givenAtInputErrors.Remove(med.FixedMedicationId);
        _medicationPlanErrors.Remove(med.FixedMedicationId);
        _givenAtInputs[med.FixedMedicationId] = GetDefaultGivenAtInputValue(med);
        _medicationEditStates[med.FixedMedicationId] = CreateMedicationEditState(med);

        return Task.CompletedTask;
    }

    private async Task RegisterFixedMedicationNowAsync(FixedMedicationDto med)
    {
        _givenAtInputs[med.FixedMedicationId] = string.Empty;
        await PersistFixedMedicationRegistrationAsync(med, useInputValue: false);
    }

    private async Task SaveFixedMedicationRegistrationAsync(FixedMedicationDto med)
    {
        await PersistFixedMedicationRegistrationAsync(med, useInputValue: true);
    }

    private async Task PersistFixedMedicationRegistrationAsync(FixedMedicationDto med, bool useInputValue)
    {
        if (_selectedCitizen == null)
        {
            return;
        }

        DateTime? givenAtUtc = null;

        if (useInputValue && !TryResolveGivenAtUtc(med.FixedMedicationId, out givenAtUtc, out var validationError))
        {
            _givenAtInputErrors[med.FixedMedicationId] = validationError;
            _error = true;
            _errorMessage = validationError;
            return;
        }

        _givenAtInputErrors.Remove(med.FixedMedicationId);

        try
        {
            _workingFixedMedicationId = med.FixedMedicationId;

            var result = await FixedMedicationApi.RegisterFixedMedicationGivenAsync(
                _selectedCitizen.CitizenId,
                med.FixedMedicationId,
                useInputValue ? givenAtUtc : null);

            if (result == null)
            {
                _error = true;
                _errorMessage = "Kunne ikke registrere medicin som givet. Serveren returnerede ikke en registrering.";
                return;
            }

            _error = false;
            _errorMessage = string.Empty;
            _givenAtInputs[med.FixedMedicationId] = GetDefaultGivenAtInputValue(result);

            // Single source of truth: reload fra server efter mutation
            await LoadFixedMedicationAsync();
            await LoadAuditEventsAsync();
        }
        catch (Exception ex)
        {
            _error = true;
            _errorMessage = $"Fejl under registrering af medicin: {ex.Message}";
        }
        finally
        {
            _workingFixedMedicationId = null;
            StateHasChanged();
        }
    }

    private async Task CancelFixedMedicationAsync(FixedMedicationDto med)
    {
        if (_selectedCitizen == null)
        {
            return;
        }

        _givenAtInputErrors.Remove(med.FixedMedicationId);

        try
        {
            _workingFixedMedicationId = med.FixedMedicationId;

            var result = await FixedMedicationApi.CancelFixedMedicationGivenAsync(
                _selectedCitizen.CitizenId,
                med.FixedMedicationId);

            if (result == null)
            {
                _error = true;
                _errorMessage = "Kunne ikke annullere den aktuelle medicinregistrering. Serveren returnerede ikke en registrering.";
                return;
            }

            _error = false;
            _errorMessage = string.Empty;

            _givenAtInputs[med.FixedMedicationId] = DateTime.Now.ToString(GivenAtDisplayFormat, CultureInfo.InvariantCulture);

            // Single source of truth: reload fra server efter mutation
            await LoadFixedMedicationAsync();
            await LoadAuditEventsAsync();
        }
        catch (Exception ex)
        {
            _error = true;
            _errorMessage = $"Fejl under annullering af aktuel medicinregistrering: {ex.Message}";
        }
        finally
        {
            _workingFixedMedicationId = null;
            StateHasChanged();
        }
    }

    private async Task SaveMedicationPlanAsync(FixedMedicationDto med)
    {
        if (_selectedCitizen == null)
        {
            return;
        }

        var editState = GetMedicationEditState(med);
        if (!TryCreatePlanRequest(editState, out var request, out var validationError))
        {
            _medicationPlanErrors[med.FixedMedicationId] = validationError;
            _error = true;
            _errorMessage = validationError;
            return;
        }

        _medicationPlanErrors.Remove(med.FixedMedicationId);

        try
        {
            _workingFixedMedicationId = med.FixedMedicationId;

            var result = await FixedMedicationApi.UpdateFixedMedicationPlanAsync(
                _selectedCitizen.CitizenId,
                med.FixedMedicationId,
                request);

            if (result == null)
            {
                _error = true;
                _errorMessage = "Kunne ikke gemme medicinplanen. Serveren returnerede ikke en registrering.";
                return;
            }

            _error = false;
            _errorMessage = string.Empty;
            _medicationEditStates[med.FixedMedicationId] = CreateMedicationEditState(result);

            await LoadFixedMedicationAsync();
        }
        catch (Exception ex)
        {
            _error = true;
            _errorMessage = $"Fejl under gem af medicinplan: {ex.Message}";
        }
        finally
        {
            _workingFixedMedicationId = null;
            StateHasChanged();
        }
    }

    private string GetGivenAtInputValue(FixedMedicationDto medication)
    {
        if (_givenAtInputs.TryGetValue(medication.FixedMedicationId, out var value))
        {
            return value;
        }

        var defaultValue = GetDefaultGivenAtInputValue(medication);
        _givenAtInputs[medication.FixedMedicationId] = defaultValue;
        return defaultValue;
    }

    private void SetGivenAtInputValue(int fixedMedicationId, object? value)
    {
        _givenAtInputs[fixedMedicationId] = NormalizeGivenAtInputValue(value);
        _givenAtInputErrors.Remove(fixedMedicationId);

        if (_error && IsMedicationTimeError(_errorMessage))
        {
            _error = false;
            _errorMessage = string.Empty;
        }
    }

    private bool TryResolveGivenAtUtc(int fixedMedicationId, out DateTime? givenAtUtc, out string validationError)
    {
        givenAtUtc = null;
        validationError = string.Empty;

        if (!_givenAtInputs.TryGetValue(fixedMedicationId, out var value) || string.IsNullOrWhiteSpace(value))
        {
            // UC04-regel: tomt tidspunkt er tilladt og betyder, at serveren bruger nuværende tidspunkt.
            return true;
        }

        var trimmedValue = value.Trim();

        if (!TryParseGivenAtInput(trimmedValue, out var parsedGivenAt))
        {
            validationError = "Tidspunktet kunne ikke læses. Vælg dato og klokkeslæt igen. Tomt felt er også tilladt og registrerer med serverens nuværende tidspunkt.";
            return false;
        }

        var localComparisonValue = parsedGivenAt.Kind == DateTimeKind.Utc
            ? parsedGivenAt.ToLocalTime()
            : parsedGivenAt;

        if (localComparisonValue < MinimumGivenAtLocal)
        {
            validationError = "Tidspunktet er ugyldigt, fordi det ligger før 01-01-2000 kl. 00:00. Vælg et nyere tidspunkt eller ryd feltet for at bruge serverens nuværende tidspunkt.";
            return false;
        }

        givenAtUtc = ConvertParsedGivenAtToUtc(parsedGivenAt);
        return true;
    }

    private static string NormalizeGivenAtInputValue(object? value)
    {
        return value switch
        {
            null => string.Empty,
            DateTime dateTime => dateTime.ToString(GivenAtDisplayFormat, CultureInfo.InvariantCulture),
            _ => value.ToString()?.Trim() ?? string.Empty
        };
    }

    private static bool TryParseGivenAtInput(string value, out DateTime parsedGivenAt)
    {
        if (DateTime.TryParseExact(
                value,
                GivenAtInputFormats,
                CultureInfo.InvariantCulture,
                DateTimeStyles.AllowWhiteSpaces,
                out parsedGivenAt))
        {
            return true;
        }

        // Fallback til browser/WebView-varianter, hvis ChangeEventArgs.Value leveres i en lokal kulturstreng.
        if (DateTime.TryParse(value, CultureInfo.CurrentCulture, DateTimeStyles.AllowWhiteSpaces, out parsedGivenAt))
        {
            return true;
        }

        if (DateTime.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AllowWhiteSpaces, out parsedGivenAt))
        {
            return true;
        }

        parsedGivenAt = default;
        return false;
    }

    private static DateTime ConvertParsedGivenAtToUtc(DateTime parsedGivenAt)
    {
        return parsedGivenAt.Kind switch
        {
            DateTimeKind.Utc => parsedGivenAt,
            DateTimeKind.Local => parsedGivenAt.ToUniversalTime(),
            _ => DateTime.SpecifyKind(parsedGivenAt, DateTimeKind.Local).ToUniversalTime()
        };
    }

    private static bool IsMedicationTimeError(string message)
    {
        return message.Contains("Tidspunkt", StringComparison.OrdinalIgnoreCase)
            || message.Contains("serverens nuværende tidspunkt", StringComparison.OrdinalIgnoreCase)
            || message.Contains("Serveren afviste tidspunktet", StringComparison.OrdinalIgnoreCase);
    }

    private void SyncGivenAtInputs(IEnumerable<FixedMedicationDto> medications)
    {
        var medicationIds = medications
            .Select(m => m.FixedMedicationId)
            .ToHashSet();

        foreach (var fixedMedicationId in _givenAtInputs.Keys.ToList())
        {
            if (!medicationIds.Contains(fixedMedicationId))
            {
                _givenAtInputs.Remove(fixedMedicationId);
                _givenAtInputErrors.Remove(fixedMedicationId);
            }
        }

        foreach (var medication in medications)
        {
            if (!_givenAtInputs.ContainsKey(medication.FixedMedicationId))
            {
                _givenAtInputs[medication.FixedMedicationId] = GetDefaultGivenAtInputValue(medication);
            }
        }
    }

    private void SyncMedicationEditStates(IEnumerable<FixedMedicationDto> medications)
    {
        var medicationIds = medications
            .Select(m => m.FixedMedicationId)
            .ToHashSet();

        foreach (var fixedMedicationId in _medicationEditStates.Keys.ToList())
        {
            if (!medicationIds.Contains(fixedMedicationId))
            {
                _medicationEditStates.Remove(fixedMedicationId);
                _medicationPlanErrors.Remove(fixedMedicationId);
            }
        }

        foreach (var medication in medications)
        {
            _medicationEditStates[medication.FixedMedicationId] = CreateMedicationEditState(medication);
        }
    }

    private FixedMedicationEditState GetMedicationEditState(FixedMedicationDto medication)
    {
        if (_medicationEditStates.TryGetValue(medication.FixedMedicationId, out var state))
