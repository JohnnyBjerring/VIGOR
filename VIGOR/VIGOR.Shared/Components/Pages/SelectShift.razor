@page "/shift/select"
@using System.Security.Claims
@using VIGOR.Shared.DTOs
@using VIGOR.Shared.Enums
@using VIGOR.Shared.Interfaces.Services
@inject IShiftSelectionApi ShiftSelectionApi
@inject IActiveShiftContextState ActiveShiftContextState
@inject NavigationManager NavigationManager

<PageTitle>Vælg aktiv vagt – VIGOR</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        @if (HasOperationalAccess(authContext.User))
        {
            <section class="vigor-page shift-select-page" aria-label="Vælg aktiv vagt">
                <header class="vigor-page-hero compact shift-hero">
                    <div>
                        <div class="vigor-eyebrow">Vagtkontekst</div>
                        <h1>Vælg aktiv vagt</h1>
                        <p>Vælg dag, aften eller nat før du arbejder videre i borgeroversigten.</p>
                    </div>
                    <div class="vigor-context-pills" aria-label="Aktiv kontekst">
                        <span class="vigor-pill">Rolle: <strong>@GetPrimaryDisplayRole(authContext.User)</strong></span>
                        <span class="vigor-pill">Aktiv vagt: <strong>@GetCurrentShiftLabel()</strong></span>
                        <span class="vigor-pill">Dato: <strong>@DateTime.Now.ToString("dd.MM.yyyy")</strong></span>
                    </div>
                </header>

                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <div class="vigor-alert danger" role="alert">@_errorMessage</div>
                }

                <section class="vigor-panel shift-panel">
                    <div class="vigor-panel-head">
                        <div>
                            <h2>Vælg vagt</h2>
                            <p>Foreslået vagt: <strong>@_suggestedShiftType.ToDanishDisplayName()</strong>. Bekræft manuelt.</p>
                        </div>
                    </div>

                    <div class="shift-card-grid">
                        @foreach (var shiftType in _shiftTypes)
                        {
                            var isSuggested = shiftType == _suggestedShiftType;
                            var isSubmitting = _submittingShiftType == shiftType;
                            var isCurrent = ActiveShiftContextState.Current?.ShiftType == shiftType;

                            <button type="button"
                                    class="shift-choice-card @(isSuggested ? "suggested" : string.Empty) @(isCurrent ? "current" : string.Empty)"
                                    disabled="@(_submittingShiftType != null)"
                                    @onclick="@(async () => await SelectShiftAsync(shiftType))">
                                <span class="shift-icon">@GetShiftIcon(shiftType)</span>
                                <strong>@shiftType.ToDanishDisplayName()</strong>
                                <small>@GetShiftDescription(shiftType)</small>

                                @if (isCurrent)
                                {
                                    <span class="shift-badge">Aktiv</span>
                                }
                                else if (isSuggested)
                                {
                                    <span class="shift-badge">Foreslået</span>
                                }

                                @if (isSubmitting)
                                {
                                    <span class="shift-loading">
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                        Gemmer...
                                    </span>
                                }
                            </button>
                        }
                    </div>

                    @if (ActiveShiftContextState.Current != null)
                    {
                        <div class="shift-current-row">
                            <div>
                                <strong>Aktuel vagtkontekst</strong>
                                <span>@ActiveShiftContextState.Current.DisplayName · valgt @ActiveShiftContextState.Current.SelectedAtUtc.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</span>
                            </div>
                            <a class="vigor-primary-button" href="citizens">Gå til borgere</a>
                        </div>
                    }
                </section>
            </section>
        }
        else
        {
            <section class="vigor-page">
                <div class="vigor-panel">
                    <h1>Ingen adgang til vagtvalg</h1>
                    <p>Denne side er kun for driftsrollerne Personale, Vagtansvarlig og Leder.</p>
                    <a class="vigor-primary-button" href="admin">Gå til administration</a>
                </div>
            </section>
        }
    </Authorized>
    <NotAuthorized>
        <section class="vigor-page">
            <div class="vigor-panel">
                <h1>Du skal være logget ind</h1>
                <p>Log ind for at vælge aktiv vagt.</p>
                <a class="vigor-primary-button" href="login">Gå til login</a>
            </div>
        </section>
    </NotAuthorized>
</AuthorizeView>

@code {
    private readonly ShiftType[] _shiftTypes =
    {
        ShiftType.Day,
        ShiftType.Evening,
        ShiftType.Night
    };

    private ShiftType _suggestedShiftType;
    private ShiftType? _submittingShiftType;
    private string _errorMessage = string.Empty;

    protected override void OnInitialized()
    {
        _suggestedShiftType = ShiftTypeExtensions.SuggestFromLocalTime(DateTime.Now.TimeOfDay);
    }

    private async Task SelectShiftAsync(ShiftType shiftType)
    {
        _errorMessage = string.Empty;
        _submittingShiftType = shiftType;

        try
        {
            var context = await ShiftSelectionApi.SelectShiftAsync(new SelectShiftRequest
            {
                ShiftType = shiftType
            });

            if (context == null)
            {
                _errorMessage = "Vagtvalget kunne ikke gemmes. Prøv igen eller log ind på ny.";
                return;
            }

            await ActiveShiftContextState.SetAsync(context);
            NavigationManager.NavigateTo("/citizens");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fejl under valg af vagt: {ex.Message}";
        }
        finally
        {
            _submittingShiftType = null;
        }
    }

    private static bool HasOperationalAccess(ClaimsPrincipal user)
    {
        return user.IsInRole("Leder")
               || user.IsInRole("Vagtansvarlig")
               || user.IsInRole("Personale");
    }

    private string GetCurrentShiftLabel()
    {
        return ActiveShiftContextState.Current?.DisplayName ?? "Ingen aktiv vagt";
    }

    private static string GetPrimaryDisplayRole(ClaimsPrincipal user)
    {
        if (user.IsInRole("Leder")) return "Leder";
        if (user.IsInRole("Vagtansvarlig")) return "Vagtansvarlig";
        if (user.IsInRole("Personale")) return "Personale";
        return "Bruger";
    }

    private static string GetShiftIcon(ShiftType shiftType)
    {
        return shiftType switch
        {
            ShiftType.Day => "☀",
            ShiftType.Evening => "◐",
            ShiftType.Night => "☾",
            _ => "•"
        };
    }

    private static string GetShiftDescription(ShiftType shiftType)
    {
        return shiftType switch
        {
            ShiftType.Day => "Morgen og formiddag",
            ShiftType.Evening => "Eftermiddag og aften",
            ShiftType.Night => "Sen aften og nat",
            _ => "Ukendt vagt"
        };
    }
}
